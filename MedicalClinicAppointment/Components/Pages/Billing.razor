@page "/billing"
@rendermode InteractiveServer
@using MedicalClinicAppointment.Models
@using MedicalClinicAppointment.Services
@inject IPatientService PatientService
@inject IDoctorService DoctorService
@inject IAppointmentService AppointmentService
@inject IBillService BillService

<PageTitle>Billing</PageTitle>

<h3 class="mb-4">Billing</h3>

<EditForm Model="@bill" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="card shadow-sm p-4">
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Patient</label>
                <InputSelect class="form-control" @bind-Value="bill.PatientId" @bind-Value:after="FilterAppointments">
                    <option value="0">-- Select Patient --</option>
                    @foreach (var patient in patients)
                    {
                        <option value="@patient.Id">@patient.FirstName @patient.LastName</option>
                    }
                </InputSelect>
                <ValidationMessage For="@(() => bill.PatientId)" />
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label">Doctor</label>
                <InputSelect class="form-control" @bind-Value="bill.DoctorId" @bind-Value:after="OnDoctorChanged">
                    <option value="0">-- Select Doctor --</option>
                    @foreach (var doctor in doctors)
                    {
                        <option value="@doctor.Id">Dr. @doctor.FirstName @doctor.LastName (@doctor.Specialization)</option>
                    }
                </InputSelect>
                <ValidationMessage For="@(() => bill.DoctorId)" />
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Appointment</label>
                <InputSelect class="form-control" @bind-Value="selectedAppointmentId">
                    <option value="">-- Optional: Select Appointment --</option>
                    @foreach (var appointment in filteredAppointments)
                    {
                        var patient = patients.FirstOrDefault(p => p.Id == appointment.PatientId);
                        var doctor = doctors.FirstOrDefault(d => d.Id == appointment.DoctorId);

                        <option value="@appointment.Id">
                            @($"{appointment.AppointmentDate:MM/dd/yyyy} {appointment.AppointmentTime} - {patient?.FirstName} {patient?.LastName} - Dr. {doctor?.FirstName} {doctor?.LastName}")
                        </option>
                    }
                </InputSelect>
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label">Bill Date</label>
                <InputDate class="form-control" @bind-Value="bill.BillDate" />
                <ValidationMessage For="@(() => bill.BillDate)" />
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Invoice Number</label>
                <InputText class="form-control" @bind-Value="bill.InvoiceNumber" readonly />
                <ValidationMessage For="@(() => bill.InvoiceNumber)" />
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label">Payment Method</label>
                <InputSelect class="form-control" @bind-Value="bill.PaymentMethod">
                    <option value="Cash">Cash</option>
                    <option value="Credit Card">Credit Card</option>
                    <option value="Debit Card">Debit Card</option>
                    <option value="Insurance">Insurance</option>
                    <option value="Online">Online</option>
                </InputSelect>
                <ValidationMessage For="@(() => bill.PaymentMethod)" />
            </div>
        </div>

        <div class="row">
            <div class="col-md-4 mb-3">
                <label class="form-label">Consultation Fee</label>
                <InputNumber class="form-control" @bind-Value="bill.ConsultationFee" @bind-Value:after="RecalculatePayableAmount" />
                <ValidationMessage For="@(() => bill.ConsultationFee)" />
            </div>

            <div class="col-md-4 mb-3">
                <label class="form-label">Insurance Coverage</label>
                <InputNumber class="form-control" @bind-Value="bill.InsuranceCoverage" @bind-Value:after="RecalculatePayableAmount" />
                <ValidationMessage For="@(() => bill.InsuranceCoverage)" />
            </div>

            <div class="col-md-4 mb-3">
                <label class="form-label">Patient Payable Amount</label>
                <InputNumber class="form-control" @bind-Value="bill.PatientPayableAmount" readonly />
                <ValidationMessage For="@(() => bill.PatientPayableAmount)" />
            </div>
        </div>

        <div class="row">
            <div class="col-md-8 mb-3">
                <label class="form-label">Notes</label>
                <InputTextArea class="form-control" @bind-Value="bill.Notes" />
            </div>

            <div class="col-md-4 mb-3">
                <label class="form-label">Payment Status</label>
                <InputSelect class="form-control" @bind-Value="bill.PaymentStatus">
                    <option value="Pending">Pending</option>
                    <option value="Paid">Paid</option>
                    <option value="Partially Paid">Partially Paid</option>
                </InputSelect>
            </div>
        </div>

        <div class="mt-3">
            <button type="submit" class="btn btn-primary me-2">Save Bill</button>
            <button type="button" class="btn btn-secondary" @onclick="LoadSampleInvoicePreview">Preview Invoice Info</button>
        </div>
    </div>
</EditForm>

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success mt-3">
        @successMessage
    </div>
}

@if (showInvoicePreview)
{
    <div class="card mt-4 shadow-sm">
        <div class="card-header">
            <h5 class="mb-0">Invoice Preview</h5>
        </div>
        <div class="card-body">
            <p><strong>Invoice Number:</strong> @bill.InvoiceNumber</p>
            <p><strong>Bill Date:</strong> @bill.BillDate.ToShortDateString()</p>
            <p><strong>Patient:</strong> @GetPatientName(bill.PatientId)</p>
            <p><strong>Doctor:</strong> @GetDoctorName(bill.DoctorId)</p>
            <p><strong>Consultation Fee:</strong> @bill.ConsultationFee.ToString("C")</p>
            <p><strong>Insurance Coverage:</strong> @bill.InsuranceCoverage.ToString("C")</p>
            <p><strong>Patient Payable:</strong> @bill.PatientPayableAmount.ToString("C")</p>
            <p><strong>Payment Method:</strong> @bill.PaymentMethod</p>
            <p><strong>Status:</strong> @bill.PaymentStatus</p>
            <p><strong>Notes:</strong> @bill.Notes</p>
        </div>
    </div>
}

@if (bills.Any())
{
    <div class="mt-4">
        <h4>Saved Bills</h4>

        <table class="table table-bordered table-striped mt-3">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Invoice No.</th>
                    <th>Patient</th>
                    <th>Doctor</th>
                    <th>Bill Date</th>
                    <th>Fee</th>
                    <th>Insurance</th>
                    <th>Payable</th>
                    <th>Method</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var savedBill in bills)
                {
                    <tr>
                        <td>@savedBill.Id</td>
                        <td>@savedBill.InvoiceNumber</td>
                        <td>@GetPatientName(savedBill.PatientId)</td>
                        <td>@GetDoctorName(savedBill.DoctorId)</td>
                        <td>@savedBill.BillDate.ToShortDateString()</td>
                        <td>@savedBill.ConsultationFee.ToString("C")</td>
                        <td>@savedBill.InsuranceCoverage.ToString("C")</td>
                        <td>@savedBill.PatientPayableAmount.ToString("C")</td>
                        <td>@savedBill.PaymentMethod</td>
                        <td>@savedBill.PaymentStatus</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private Bill bill = new();
    private int? selectedAppointmentId;
    private List<Patient> patients = new();
    private List<Doctor> doctors = new();
    private List<Appointment> appointments = new();
    private List<Appointment> filteredAppointments = new();
    private List<Bill> bills = new();
    private string successMessage = string.Empty;
    private bool showInvoicePreview = false;

    protected override async Task OnInitializedAsync()
    {
        patients = await PatientService.GetAllPatientsAsync();
        doctors = await DoctorService.GetAllDoctorsAsync();
        appointments = await AppointmentService.GetAllAppointmentsAsync();
        bills = await BillService.GetAllBillsAsync();

        ResetBill();
        FilterAppointments();
    }

    private void ResetBill()
    {
        bill = new Bill
        {
            BillDate = DateTime.Today,
            PaymentStatus = "Pending",
            PaymentMethod = "Cash",
            InvoiceNumber = BillService.GenerateNextInvoiceNumber()
        };

        selectedAppointmentId = null;
        showInvoicePreview = false;
    }

    private void FilterAppointments()
    {
        filteredAppointments = appointments
            .Where(a =>
                (bill.PatientId == 0 || a.PatientId == bill.PatientId) &&
                (bill.DoctorId == 0 || a.DoctorId == bill.DoctorId))
            .ToList();
    }

    private void OnDoctorChanged()
    {
        var doctor = doctors.FirstOrDefault(d => d.Id == bill.DoctorId);

        if (doctor is not null)
        {
            bill.ConsultationFee = doctor.ConsultationFee;
        }

        FilterAppointments();
        RecalculatePayableAmount();
    }

    private void RecalculatePayableAmount()
    {
        bill.PatientPayableAmount = bill.ConsultationFee - bill.InsuranceCoverage;

        if (bill.PatientPayableAmount < 0)
        {
            bill.PatientPayableAmount = 0;
        }
    }

    private async Task HandleValidSubmit()
    {
        bill.AppointmentId = selectedAppointmentId;
        RecalculatePayableAmount();

        var billToSave = new Bill
        {
            PatientId = bill.PatientId,
            DoctorId = bill.DoctorId,
            AppointmentId = bill.AppointmentId,
            InvoiceNumber = bill.InvoiceNumber,
            BillDate = bill.BillDate,
            ConsultationFee = bill.ConsultationFee,
            InsuranceCoverage = bill.InsuranceCoverage,
            PatientPayableAmount = bill.PatientPayableAmount,
            PaymentMethod = bill.PaymentMethod,
            Notes = bill.Notes,
            PaymentStatus = bill.PaymentStatus
        };

        await BillService.AddBillAsync(billToSave);

        successMessage = $"Bill {bill.InvoiceNumber} saved successfully.";
        bills = await BillService.GetAllBillsAsync();

        ResetBill();
        FilterAppointments();
    }

    private void LoadSampleInvoicePreview()
    {
        RecalculatePayableAmount();
        showInvoicePreview = true;
    }

    private string GetPatientName(int patientId)
    {
        var patient = patients.FirstOrDefault(p => p.Id == patientId);
        return patient is null ? string.Empty : $"{patient.FirstName} {patient.LastName}";
    }

    private string GetDoctorName(int doctorId)
    {
        var doctor = doctors.FirstOrDefault(d => d.Id == doctorId);
        return doctor is null ? string.Empty : $"Dr. {doctor.FirstName} {doctor.LastName}";
    }
}