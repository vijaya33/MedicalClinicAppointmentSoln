
@page "/doctors/manage"
@rendermode InteractiveServer
@using MedicalClinicAppointment.Models
@using MedicalClinicAppointment.Services
@inject IDoctorService DoctorService

<PageTitle>Doctor Management</PageTitle>

<h3 class="mb-4">Doctor Management</h3>

<EditForm Model="@doctor" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="card shadow-sm p-4">
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">First Name</label>
                <InputText class="form-control" @bind-Value="doctor.FirstName" />
                <ValidationMessage For="@(() => doctor.FirstName)" />
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label">Last Name</label>
                <InputText class="form-control" @bind-Value="doctor.LastName" />
                <ValidationMessage For="@(() => doctor.LastName)" />
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Specialization</label>
                <InputText class="form-control" @bind-Value="doctor.Specialization" />
                <ValidationMessage For="@(() => doctor.Specialization)" />
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label">Email</label>
                <InputText class="form-control" @bind-Value="doctor.Email" />
                <ValidationMessage For="@(() => doctor.Email)" />
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Phone Number</label>
                <InputText class="form-control" @bind-Value="doctor.PhoneNumber" />
                <ValidationMessage For="@(() => doctor.PhoneNumber)" />
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label">Consultation Fee</label>
                <InputNumber class="form-control" @bind-Value="doctor.ConsultationFee" />
                <ValidationMessage For="@(() => doctor.ConsultationFee)" />
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Working Hours</label>
                <InputText class="form-control" @bind-Value="doctor.WorkingHours" />
                <ValidationMessage For="@(() => doctor.WorkingHours)" />
            </div>

            <div class="col-md-6 mb-3 d-flex align-items-center mt-4">
                <div class="form-check">
                    <InputCheckbox class="form-check-input" @bind-Value="doctor.IsActive" />
                    <label class="form-check-label ms-2">Active Doctor</label>
                </div>
            </div>
        </div>

        <div class="mt-3">
            <button type="submit" class="btn btn-primary">Save Doctor</button>
        </div>
    </div>
</EditForm>

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success mt-3">
        @successMessage
    </div>
}

@if (doctors.Any())
{
    <div class="mt-4">
        <h4>Registered Doctors</h4>

        <table class="table table-bordered table-striped mt-3">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Doctor Name</th>
                    <th>Specialization</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Fee</th>
                    <th>Working Hours</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in doctors)
                {
                    <tr>
                        <td>@d.Id</td>
                        <td>Dr. @d.FirstName @d.LastName</td>
                        <td>@d.Specialization</td>
                        <td>@d.Email</td>
                        <td>@d.PhoneNumber</td>
                        <td>@d.ConsultationFee.ToString("C")</td>
                        <td>@d.WorkingHours</td>
                        <td>@(d.IsActive ? "Active" : "Inactive")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private Doctor doctor = new()
    {
        IsActive = true
    };

    private List<Doctor> doctors = new();
    private string successMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        doctors = await DoctorService.GetAllDoctorsAsync();
    }

    private async Task HandleValidSubmit()
    {
        await DoctorService.AddDoctorAsync(doctor);

        successMessage = $"Doctor '{doctor.FirstName} {doctor.LastName}' saved successfully.";

        doctor = new Doctor
        {
            IsActive = true
        };

        doctors = await DoctorService.GetAllDoctorsAsync();
    }
}
