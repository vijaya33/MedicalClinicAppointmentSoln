@code {

}

@page "/patients/register"
@rendermode InteractiveServer
@using MedicalClinicAppointment.Models
@using MedicalClinicAppointment.Services
@inject IPatientService PatientService

<PageTitle>Patient Registration</PageTitle>

<h3 class="mb-4">Patient Registration</h3>

<EditForm Model="@patient" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="card shadow-sm p-4">
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">First Name</label>
                <InputText class="form-control" @bind-Value="patient.FirstName" />
                <ValidationMessage For="@(() => patient.FirstName)" />
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label">Last Name</label>
                <InputText class="form-control" @bind-Value="patient.LastName" />
                <ValidationMessage For="@(() => patient.LastName)" />
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Email</label>
                <InputText class="form-control" @bind-Value="patient.Email" />
                <ValidationMessage For="@(() => patient.Email)" />
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label">Phone Number</label>
                <InputText class="form-control" @bind-Value="patient.PhoneNumber" />
                <ValidationMessage For="@(() => patient.PhoneNumber)" />
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Date of Birth</label>
                <InputDate class="form-control" @bind-Value="patient.DateOfBirth" />
                <ValidationMessage For="@(() => patient.DateOfBirth)" />
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label">Address</label>
                <InputText class="form-control" @bind-Value="patient.Address" />
                <ValidationMessage For="@(() => patient.Address)" />
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Insurance Provider</label>
                <InputText class="form-control" @bind-Value="patient.InsuranceProvider" />
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label">Policy Number</label>
                <InputText class="form-control" @bind-Value="patient.PolicyNumber" />
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Emergency Contact Name</label>
                <InputText class="form-control" @bind-Value="patient.EmergencyContactName" />
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label">Emergency Contact Phone</label>
                <InputText class="form-control" @bind-Value="patient.EmergencyContactPhone" />
                <ValidationMessage For="@(() => patient.EmergencyContactPhone)" />
            </div>
        </div>

        <div class="mt-3">
            <button type="submit" class="btn btn-primary">Register Patient</button>
        </div>
    </div>
</EditForm>

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success mt-3">
        @successMessage
    </div>
}

@if (patients.Any())
{
    <div class="mt-4">
        <h4>Registered Patients</h4>

        <table class="table table-bordered table-striped mt-3">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Patient Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Date of Birth</th>
                    <th>Insurance Provider</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in patients)
                {
                    <tr>
                        <td>@p.Id</td>
                        <td>@p.FirstName @p.LastName</td>
                        <td>@p.Email</td>
                        <td>@p.PhoneNumber</td>
                        <td>@p.DateOfBirth.ToShortDateString()</td>
                        <td>@p.InsuranceProvider</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private Patient patient = new()
    {
        DateOfBirth = DateTime.Today.AddYears(-18)
    };

    private List<Patient> patients = new();
    private string successMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        patients = await PatientService.GetAllPatientsAsync();
    }

    private async Task HandleValidSubmit()
    {
        await PatientService.AddPatientAsync(patient);

        successMessage = $"Patient '{patient.FirstName} {patient.LastName}' registered successfully.";

        patient = new Patient
        {
            DateOfBirth = DateTime.Today.AddYears(-18)
        };

        patients = await PatientService.GetAllPatientsAsync();
    }
}
