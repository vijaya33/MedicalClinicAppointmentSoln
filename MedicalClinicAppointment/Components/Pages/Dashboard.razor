@page "/dashboard"
@rendermode InteractiveServer
@using MedicalClinicAppointment.Models
@using MedicalClinicAppointment.Services
@inject IDashboardService DashboardService
@inject IPatientService PatientService
@inject IDoctorService DoctorService

<PageTitle>My Dashboard</PageTitle>

<h3 class="mb-4">Clinic Dashboard</h3>

@if (summary is null)
{
    <p>Loading dashboard...</p>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm p-3">
                <h6>Total Patients</h6>
                <h3>@summary.TotalPatients</h3>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm p-3">
                <h6>Total Doctors</h6>
                <h3>@summary.TotalDoctors</h3>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm p-3">
                <h6>Total Appointments</h6>
                <h3>@summary.TotalAppointments</h3>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm p-3">
                <h6>Total Bills</h6>
                <h3>@summary.TotalBills</h3>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm p-3">
                <h6>Pending Payments</h6>
                <h3>@summary.PendingPaymentsCount</h3>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm p-3">
                <h6>Total Billed</h6>
                <h3>@summary.TotalBilledAmount.ToString("C")</h3>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm p-3">
                <h6>Total Collected</h6>
                <h3>@summary.TotalCollectedAmount.ToString("C")</h3>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm p-3">
                <h6>Outstanding</h6>
                <h3>@summary.TotalOutstandingAmount.ToString("C")</h3>
            </div>
        </div>
    </div>

    <div class="card shadow-sm p-4">
        <h4>Today's Appointments</h4>

        @if (todayAppointments.Any())
        {
            <table class="table table-bordered table-striped mt-3">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Patient</th>
                        <th>Doctor</th>
                        <th>Date</th>
                        <th>Time</th>
                        <th>Reason</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var appointment in todayAppointments)
                    {
                        <tr>
                            <td>@appointment.Id</td>
                            <td>@GetPatientName(appointment.PatientId)</td>
                            <td>@GetDoctorName(appointment.DoctorId)</td>
                            <td>@appointment.AppointmentDate.ToShortDateString()</td>
                            <td>@appointment.AppointmentTime</td>
                            <td>@appointment.ReasonForVisit</td>
                            <td>@appointment.Status</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="mt-3">No appointments scheduled for today.</p>
        }
    </div>
}

@code {
    private DashboardSummary? summary;
    private List<Appointment> todayAppointments = new();
    private List<Patient> patients = new();
    private List<Doctor> doctors = new();

    protected override async Task OnInitializedAsync()
    {
        summary = await DashboardService.GetDashboardSummaryAsync();
        todayAppointments = await DashboardService.GetTodayAppointmentsAsync();
        patients = await PatientService.GetAllPatientsAsync();
        doctors = await DoctorService.GetAllDoctorsAsync();
    }

    private string GetPatientName(int patientId)
    {
        var patient = patients.FirstOrDefault(p => p.Id == patientId);
        return patient is null ? string.Empty : $"{patient.FirstName} {patient.LastName}";
    }

    private string GetDoctorName(int doctorId)
    {
        var doctor = doctors.FirstOrDefault(d => d.Id == doctorId);
        return doctor is null ? string.Empty : $"Dr. {doctor.FirstName} {doctor.LastName}";
    }
}